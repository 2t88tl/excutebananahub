local function saveState(state)
    pcall(function()
        writefile(STATE_FILE, HttpService:JSONEncode(state))
    end)
end

local function loadState()
    local ok, raw = pcall(readfile, STATE_FILE)
    if not ok or not raw or raw == "" then return {} end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    return ok2 and data or {}
end

local function clearState(name)
    local s = loadState()
    s[name] = nil
    saveState(s)
end

local function updateState(name, endTime)
    local s = loadState()
    s[name] = {endTime = endTime}
    saveState(s)
end

