local pingSamples, fpsSamples = {}, {}
local statsStart = tick()

local function smooth(tbl, val)
    table.insert(tbl, val)
    if #tbl > 10 then table.remove(tbl, 1) end
    local s = 0
    for _, v in ipairs(tbl) do s += v end
    return math.floor(s / #tbl)
end

local function rainbowHex()
    local t = tick() * 1.5
    return string.format("rgb(%d,%d,%d)",
        math.floor(math.sin(t)     * 100 + 155),
        math.floor(math.sin(t + 2) * 100 + 155),
        math.floor(math.sin(t + 4) * 100 + 155)
    )
end

RunService.RenderStepped:Connect(function(dt)
    local fps  = smooth(fpsSamples, dt > 0 and math.floor(1 / dt) or 0)
    local ping = 0
    pcall(function()
        ping = smooth(pingSamples, Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    end)
    local players = #Players:GetPlayers()
    local e = math.floor(tick() - statsStart)
    local h, m, s = math.floor(e / 3600), math.floor((e % 3600) / 60), e % 60

    local fpsCol  = fps  < 20  and "rgb(255,80,80)"  or fps  < 25 and "rgb(255,180,60)" or rainbowHex()
    local pingCol = ping > 200 and "rgb(255,80,80)"  or ping > 100 and "rgb(255,180,60)" or rainbowHex()
    local col     = rainbowHex()

    StatsLabel.Text = string.format(
        "<b><font color='%s'>⚡ FPS: %d</font>  <font color='%s'>👥 Players: %d</font></b>\n" ..
        "<b><font color='%s'>📶 Ping: %d ms</font>  <font color='%s'>⏱ %02d:%02d:%02d</font></b>",
        fpsCol, fps, col, players,
        pingCol, ping, col, h, m, s
    )
end)

