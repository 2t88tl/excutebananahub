-- =====================
-- AUTO EXEC ENGINE
-- =====================
local activeTimers = {}
local activeConns  = {}
local btnDataMap   = {}

local function stopScript(name)
    if activeTimers[name] then
        task.cancel(activeTimers[name])
        activeTimers[name] = nil
    end
    if activeConns[name] then
        activeConns[name]:Disconnect()
        activeConns[name] = nil
    end
    clearState(name)
end

local function startCountdown(name, endTime)
    if activeConns[name] then activeConns[name]:Disconnect() end
    activeConns[name] = RunService.Heartbeat:Connect(function()
        local rem = endTime - os.time()
        local bd  = btnDataMap[name]
        if rem <= 0 then
            TimerLabel.Text = "⏹ " .. name .. " ended"
            activeConns[name]:Disconnect()
            activeConns[name] = nil
            if bd then
                bd.status.Text      = "⏹ Stopped (1h)"
                bd.status.TextColor3 = C.TEXT_SUB
            end
        else
            TimerLabel.Text = "⏱ " .. name .. " → " .. formatTime(rem)
        end
    end)
end

local function execScript(name)
    local code = SCRIPTS[name]
    if not code then return false end
    local ok, err = pcall(function() loadstring(code)() end)
    if not ok then warn("BCH [" .. name .. "]: " .. tostring(err)) end
    return ok
end

local function startScript(name, endTime)
    stopScript(name)
    endTime = endTime or (os.time() + AUTO_EXEC_DURATION)
    updateState(name, endTime)

    local bd = btnDataMap[name]
    if bd then
        bd.status.Text       = "⟳ Loading..."
        bd.status.TextColor3 = C.ACCENT
    end

    task.spawn(function()
        local ok = execScript(name)
        if bd then
            bd.status.Text       = ok and "✓ Running" or "✗ Error"
            bd.status.TextColor3 = ok and C.GREEN or C.RED
        end
    end)

    startCountdown(name, endTime)

    activeTimers[name] = task.spawn(function()
        while true do
            task.wait(AUTO_EXEC_INTERVAL)
            local state = loadState()
            local info  = state[name]
            if not info or os.time() >= info.endTime then
                clearState(name)
                if bd then
                    bd.status.Text       = "⏹ Stopped (1h)"
                    bd.status.TextColor3 = C.TEXT_SUB
                end
                TimerLabel.Text = "⏹ " .. name .. " ended"
                break
            end
            task.spawn(function() execScript(name) end)
        end
        activeTimers[name] = nil
    end)
end

